                  <property name="styleSheet">
                   <string notr="true">#listWidget {
                background-color:transparent; 
                color: white;
                border-radius: 10px; 
                border: 1px solid transparent;
                padding: 5px; 
                outline: 0; /* Bỏ đường viền đứt nét khi được chọn */
            }
            
            /* Cấu hình cho TỪNG DÒNG (item) bên trong list */
            #listWidget::item { 
                border-radius: 12px; /* Đặt độ bo góc bạn muốn ở đây */
                margin: 2px 4px; /* Tạo khoảng trống xung quanh để thấy rõ góc bo */
            }
            
            /* Hiệu ứng khi HOVER vào dòng */
            #listWidget::item:hover { 
                background-color: rgb(67, 67, 67); 
            }
            
            /* Hiệu ứng khi CLICK (chọn) dòng */
            #listWidget::item:selected {
                background-color: rgb(80, 80, 80);
                color: #1ED761;
            }</string>
