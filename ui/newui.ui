                  <property name="styleSheet">
                   <string notr="true">#enterWidget {
    /* Quan trọng: Phải có border thì radius mới hoạt động chuẩn */
    border: 2px solid transparent; 
    border-radius: 25px; /* Chỉnh số này cho đến khi vừa ý */
	background-color: black;
    color: white;
    padding: 5px 15px; /* Cho chữ cách lề ra một chút nhìn sẽ sang hơn */
}

#enterWidget:hover{
    /* Quan trọng: Phải có border thì radius mới hoạt động chuẩn */
    border: 2px solid transparent; 
    border-radius: 25px; /* Chỉnh số này cho đến khi vừa ý */
	background-color: rgb(52, 52, 52);
    color: white;
    padding: 5px 15px; /* Cho chữ cách lề ra một chút nhìn sẽ sang hơn */
}

#enterWidget:focus{
